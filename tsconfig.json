{
    "include": ["src/**/*.ts"],
    "exclude": ["**/*.test.ts"],
    "compilerOptions": {
        "module": "esnext",
        "target": "esnext",
        "lib": ["esnext"],
        "declaration": true,
        "strict": true,
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": "src"
    }
}
