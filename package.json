{
    "name": "war2-pud",
    "version": "1.2.0",
    "description": "Library to manipulate Warcraft II's pud files",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/ test/ --fix",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "library",
        "warcraft ii",
        "warcraft 2",
        "pud"
    ],
    "author": "Rychellos",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Rychellos/war2-pud.git"
    },
    "bugs": {
        "url": "https://github.com/Rychellos/war2-pud/issues"
    },
    "homepage": "https://github.com/Rychellos/war2-pud#readme",
    "packageManager": "pnpm@10.33.0",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.4.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "jiti": "^2.6.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "neverthrow": "^8.2.0"
    }
}
